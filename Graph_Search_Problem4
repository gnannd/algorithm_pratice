/*백준 11657 타임머신
N개의 정점(500이하), M간선(6000이하)가 주어지고 , 간선은 가중치가 있으며 음의 값을 가질 수 있다.(-10000<c<10000)
1번 정점에서 각 정점까지의 최단 경로값을 구해라. 단,정점까지의 경로가 없으면 -1을 출력해라. 음의 사이클이 있으면 최종결과 값으로 -1을 출력.
음의 가중치가 있는 방향그래프 최단경로 구하는 문제로, 시작점을 0으로 잡고,나머지를 무한(여기서 1e9로잡음) 모든 간선을 검사하여, 각정점까지의 최단거리 값을
완화하면 된다. 이 동작을 한번할 때마다 각정점까지의 최단경로중 첫 번째로 만나는 정점의 최단경로값을 보장 받기 때문에
최대정점개수-1번 반복하면 모든 정점까지의 최단 거리 값을 구할 수 있다. 그 후에도 계속 완화가 된다면 음의 사이클이 있는 것으로 판단하면 된다.
더하여, 어느 정점까지의 경로가 없는 경우는 거리값이 1e11/2이하가 되질 않으면 경로가 없는걸로 판단했다.
모든 간선을 검사하기 때문에 시작점에서 가는 경로가 없더라도 업데이트가 될 수 있다. 그래서 우리가 잡은 무한값 1e11에서 
최대한 완하 되더라도 경로가 없는 정점은 1e11/2 이하값을 가질 수 없기 때문이다. 그리고 정점까지의 최소 거리값으로 나올 수 
있는 최대값은 500*10000*600이라 1e11/2값을 초과할 걱정도 없다.

이문제에서 의문이 있었던 부분이 시작점에서 어느 정점으로 가는 경로가 없으면 그 정점에서 음의 사이클이 
있더라도 전체 결과값을 -1로 출력하면 안된다는 점이었다. 이부분은 경로가 없는 정점에 대해 -1을 출력 하는 식으로 구현 했어야 했다.
n번째 모든 간선에 대해 검사할 때 완화가 일어나는 경우, 그정점까지의 값이 1e11/2 이하인 것이 있으면 경로가 있으면서 음의 사이클이 있는것이고 
없으면 음의 사이클은 있는 곳까지 경로가 없는 것으로 판단하여 해결하였다.


참고로 이 알고리즘을 벨만 포드 알고리즘이라고 부른다.




시간복잡도: O(N*M)으로 시간내에 충분히 수행가능하다.

*/

#include <iostream>
#include <vector>
#include <utility>

using namespace std;

int main()
{
    int n,m;
    cin>>n>>m;
    vector<vector<pair<int,int>>>v(n+1);                     
    for(int i=0;i<m;i++)
    {
        int a,b,d;
        cin>>a>>b>>d;
        v[a].push_back(make_pair(b,d));
    }
    vector<long long>dist(n+1,1e11);
    dist[1]=0;
    bool ok=false;
    for(int i=0;i<n;i++)
    {
        ok=false;
        for(int j=1;j<=n;j++)
        {
            for(int r=0;r<v[j].size();r++)
            {
                if(dist[j]+v[j][r].second<dist[v[j][r].first])
                {
                    dist[v[j][r].first]=dist[j]+v[j][r].second;
                    if(i==n-1) //음의 사이클에 포함된 노드
                    {
                        if(dist[v[j][r].first]<(1e11/2))
                        {
                            ok=true;
                        }
                    }
                    else
                        ok=true;
                }
            }
        }
        if(!ok) break;
    }
    if(ok==true)
    {
        cout<<-1;
    }
    else
    {
        for(int i=2;i<=n;i++)
        {
            if(dist[i]<(1e11/2))
                cout<<dist[i]<<'\n';
            else
                cout<<-1<<'\n';
        }
    }
    return 0;
}
