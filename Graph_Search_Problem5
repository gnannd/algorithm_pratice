/*백준 4179 불!
R,C격자판이 주어진다.(<1000)
격자판의 정보는 다음 4가지 종류가 있는데,
#:지날 수 없는 벽
.:지날 수 있는 공간
J:내가 있는 위치
F:불의 위치
나 , 불 은 상하좌우 방향으로 매분마다 움직이며 불은 확산되어 간다고 할때, 
내가 얼마나 빠른 시간내에 탈출할 수 있는지 출력하라, 불에 타기전에 탈출 하지 못할 때는 impossible를 출력하라.
탈출은 격자판 가장자리에서 탈출할 수 있다고 한다.

너비우선탐색으로 풀 수 있다.
먼저 내가 이동한 방향과 상관없이 불은 계속 확산 되기에 불의 초기위치로부터 너비우선탐색을 돌려
위치마다 불이 붙는 시간을 저장해둔다.
그리고 지훈이 위치에서 너비우선탐색을 통해 갈 수 있는 위치를 그위치에 불이 붙는 시간을 확인하면서 
탐색한다.
격자판 가장자리 나갈 수 없다면 IMPOSSIBLE를 출력한다.

시간복잡도는 O(R*C) 시간내에 충분히 풀 수 있다.

*/

#include <iostream>
#include <vector>
#include <queue>
#include <utility>

using namespace std;

int dy[4]={0,1,-1,0};
int dx[4]={1,0,0,-1};

int main()
{
    int r,c;
    cin>>r>>c;
    vector<vector<int>>graph(r,vector<int>(c));
    queue<pair<int,int>>q;
    pair<int,int>start;
    for(int i=0;i<r;i++)
    {
        string s;
        cin>>s;
        for(int j=0;j<c;j++)
        {
            if(s[j]=='#')
            {
                graph[i][j]=-1;
            }
            else if(s[j]=='J')
            {
                graph[i][j]=0;
                start=make_pair(i,j);
            }
            else if(s[j]=='.')
            {
                graph[i][j]=0;
            }
            else
            {
                graph[i][j]=1;
                q.push(make_pair(i,j));
            }
        }
    }
    while(q.size())
    {
        pair<int,int>pos=q.front();
        q.pop();
        for(int i=0;i<4;i++)
        {
            if(pos.first+dy[i]>=0 and pos.first+dy[i]<r and pos.second+dx[i]>=0 and pos.second+dx[i]<c)
            {
                if(graph[pos.first+dy[i]][pos.second+dx[i]]==0)
                {
                    graph[pos.first+dy[i]][pos.second+dx[i]]=graph[pos.first][pos.second]+1;
                    q.push(make_pair(pos.first+dy[i],pos.second+dx[i]));
                }
            }
        }
    }
    q.push(start);
    vector<vector<int>>dist(r,vector<int>(c,0));
    dist[start.first][start.second]=1;
    while(q.size())
    {
        pair<int,int>pos=q.front();
        if(pos.first==r-1 or pos.first==0 or pos.second==c-1 or pos.second==0)
        {
            cout<<dist[pos.first][pos.second];
            break;
        }
        q.pop();
        for(int i=0;i<4;i++)
        {
            if(dist[pos.first+dy[i]][pos.second+dx[i]]==0)
            {
                if(graph[pos.first+dy[i]][pos.second+dx[i]]==0 or dist[pos.first][pos.second]+1<graph[pos.first+dy[i]][pos.second+dx[i]])
                {
                    dist[pos.first+dy[i]][pos.second+dx[i]]=dist[pos.first][pos.second]+1;
                    q.push(make_pair(pos.first+dy[i],pos.second+dx[i]));
                }
            }
            
        }
    }
    if(!q.size()) cout<<"IMPOSSIBLE";
    
    return 0;
}
